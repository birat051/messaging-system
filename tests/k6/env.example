# k6: copy to `.env`, then: set -a && source tests/k6/.env && set +a && k6 run tests/k6/scenarios/stepping.js
# (Values become k6 `__ENV`; see `config.js` / `getConfig()`.)

# REST base URL including /v1
BASE_URL=http://localhost:8080/v1
# WebSocket (Socket.IO) origin only, no path
WS_URL=http://localhost:8080
# JSON array of test users: path **relative to tests/k6/** (e.g. `users.json`) or repo style `tests/k6/users.json`
USER_POOL_FILE=users.json
# Tag for this run (metrics / logs)
RUN_ID=k6-local

# Target sends per second per active VU (sleep spacing)
MESSAGE_RATE=0.2
# Chance an iteration is treated as a media send (0–1; future presign)
MEDIA_RATIO=0
# Receipt test depth: none | delivered_only | full
RECEIPT_MODE=full
# Refresh JWT if it expires within this many seconds
K6_JWT_BUFFER_SEC=120
# Min random think time before actions (seconds)
K6_THINK_MIN_SEC=0
# Max random think time (seconds; uniform in [min,max])
K6_THINK_MAX_SEC=0.5
# Back-to-back messages per send burst
K6_BURST_COUNT=1
# Sleep between messages inside a burst (seconds)
K6_BURST_INNER_SEC=0.05
# Fraction of iterations that send vs connect-only idle (0–1)
K6_ACTIVE_SEND_PROB=1
# How long to keep both sockets on idle iterations (seconds)
K6_IDLE_HOLD_SEC=3
# After delivered receipt, wait this long before read (ms)
K6_RECEIPT_READ_DELAY_MS=200
# Optional pause before conversation:read (ms)
K6_RECEIPT_CONVERSATION_DELAY_MS=0
# Extra think when simulating a media send (seconds)
K6_MEDIA_SIMULATE_SEC=0.15
# Min extra `pad` bytes in message body JSON
K6_TEXT_BODY_PAD_MIN_BYTES=0
# Max extra `pad` bytes (uniform in [min,max] when max > 0)
K6_TEXT_BODY_PAD_MAX_BYTES=0
# Socket.IO wait timeout for long-poll and similar (ms)
K6_SIO_MAX_WAIT_MS=90000

# Total time to ramp 0 → target VUs (stepping.js)
K6_RAMP_UP_DURATION=5m
# Number of ramp-up steps; 1 = single linear ramp
K6_RAMP_STEPS=1
# Time at full target VUs after ramp-up
K6_SUSTAIN_DURATION=10m
# Time to ramp target → 0; omit to mirror K6_RAMP_UP_DURATION; 0s = no ramp down
# K6_RAMP_DOWN_DURATION=5m
# Number of ramp-down steps; defaults to K6_RAMP_STEPS
# K6_RAMP_DOWN_STEPS=1
# Cap VUs (pool-derived max is lower if the pool is small)
# K6_MAX_VUS=
