# Optional: copy to `.env` in the repository root (same directory you run `docker compose` from)
# so Compose substitutes variables. Defaults match docker-compose.yml.

# RabbitMQ (must match RABBITMQ_URL user:pass in messaging-service)
# RABBITMQ_USER=messaging
# RABBITMQ_PASS=messaging

# MinIO console / S3 API — messaging-service uses these for S3-compatible uploads when S3_* is set in Compose
# MINIO_ROOT_USER=minio
# MINIO_ROOT_PASSWORD=minioadmin
# S3_BUCKET=messaging-media
# S3_PUBLIC_BASE_URL=http://localhost:9000   # browser MinIO API — also used for pre-signed PUT URLs when S3_ENDPOINT is internal (e.g. minio:9000 in Docker)
# S3_PRESIGN_ENDPOINT=http://localhost:9000    # optional override if presign PUT must hit a different API origin than S3_PUBLIC_BASE_URL (e.g. direct R2 vs CloudFront reads)
# S3_ANONYMOUS_GET_OBJECT=true   # Compose default: public read for MinIO so <img src> URLs work (see README)
#
# Cloudflare R2 (S3-compatible) — server-side only; never expose in VITE_* or the web client
# CLOUDFLARE_R2_ACCOUNT_ID=<32-char hex account id from Cloudflare dashboard>
# If S3_ENDPOINT is unset, defaults to https://<CLOUDFLARE_R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# S3_BUCKET=<your R2 bucket name>
# AWS_ACCESS_KEY_ID=<R2 API token access key id>
# AWS_SECRET_ACCESS_KEY=<R2 API token secret access key>
# MEDIA_PRESIGN_TTL_SECONDS=300   # optional; TTL for GET/POST /v1/media/presign pre-signed PUT URLs (60–3600)
# JWT_SECRET=dev-only-change-for-production   # HS256 for POST /v1/media/upload in production-like Compose
# EMAIL_VERIFICATION_REQUIRED=false   # default: skip email verification on register; set true to require verify-email flow
# GUEST_SESSIONS_ENABLED=true   # default until MongoDB system_config.guestSessionsEnabled is set (Feature 2a / POST /auth/guest)
# SENDGRID_API_KEY=   # when EMAIL_VERIFICATION_REQUIRED=true — API key from SendGrid (do not commit real keys)
# EMAIL_FROM=noreply@yourdomain.com   # verified sender in SendGrid
# PUBLIC_APP_BASE_URL=https://localhost:5173   # web app origin for verification links (no trailing slash)
# EMAIL_VERIFICATION_WEB_PATH=/verify-email   # optional; default shown
# REFRESH_TOKEN_TTL_SECONDS=604800   # opaque refresh tokens in Redis (default 7d; registered users)
# GUEST_ACCESS_TOKEN_TTL_SECONDS=1800   # guest access JWT (default 30 min)
# GUEST_REFRESH_TOKEN_TTL_SECONDS=1800   # guest refresh in Redis EX TTL (default 30 min; align with guest access)
# GUEST_DATA_TTL_ENABLED=true   # MongoDB guestDataExpiresAt on guest users + guest↔guest conversations/messages (default on)
# GUEST_DATA_MONGODB_TTL_SECONDS=86400   # horizon (seconds) for guestDataExpiresAt when TTL is on
# GUEST_AUTH_RATE_LIMIT_WINDOW_SEC=3600
# GUEST_AUTH_RATE_LIMIT_MAX_PER_IP=20
# GUEST_AUTH_RATE_LIMIT_MAX_PER_FINGERPRINT=10   # when X-Client-Fingerprint is sent
# GUEST_MESSAGE_SEND_RATE_LIMIT_MAX_PER_USER=30   # guest userId cap per MESSAGE_SEND_RATE_LIMIT_WINDOW_SEC
# GUEST_USER_SEARCH_RATE_LIMIT_WINDOW_SEC=60
# GUEST_USER_SEARCH_RATE_LIMIT_MAX=30   # GET /users/search when caller is guest (separate Redis key from registered)
# PASSWORD_RESET_TOKEN_TTL_HOURS=1
# PASSWORD_RESET_WEB_PATH=/reset-password
# MEDIA_MAX_BYTES=104857600  # optional; default 100 MiB per file (image/video) and presign contentLength max

# LOG_LEVEL=info
# MONGODB_DB_NAME=messaging

# Optional: horizontal scale — same Redis as REDIS_URL; separate pub/sub connections
# SOCKET_IO_REDIS_ADAPTER=true

# Optional: last-seen key TTL (seconds); default 604800 (7d)
# LAST_SEEN_TTL_SECONDS=604800

# Global per-IP REST rate limit (Redis fixed window) — see README.md (Configuration)
# GLOBAL_RATE_LIMIT_WINDOW_SEC=60
# GLOBAL_RATE_LIMIT_MAX=500

# POST /v1/users/me/sync/message-keys — per-user Redis fixed window (see README: DEVICE_SYNC_RATE_LIMIT_*)
# DEVICE_SYNC_RATE_LIMIT_WINDOW_SEC=3600
# DEVICE_SYNC_RATE_LIMIT_MAX=120
# Legacy names (used only when the canonical vars above are unset):
# DEVICE_SYNC_BATCH_RATE_LIMIT_WINDOW_SEC=3600
# DEVICE_SYNC_BATCH_RATE_LIMIT_MAX=120
# DEVICE_SYNC_BATCH_JSON_BODY_MAX_BYTES=524288
# POST /v1/users/me/devices/sync-notify — re-broadcast device:sync_requested (blocked-device UX)
# DEVICE_SYNC_NOTIFY_RATE_LIMIT_WINDOW_SEC=3600
# DEVICE_SYNC_NOTIFY_RATE_LIMIT_MAX=60

# --- WebRTC / coturn (optional: docker compose --profile turn) ---
# TURN static user in infra/coturn/turnserver.conf is dev-only (user=dev:turnsecret).
# Web-client ICE: VITE_WEBRTC_TURN_URLS=turn:127.0.0.1:3478  VITE_WEBRTC_TURN_USERNAME=dev  VITE_WEBRTC_TURN_CREDENTIAL=turnsecret
# Ports: 3478 tcp+udp (STUN/TURN), 49152-49200 udp (relay) — README.md (WebRTC: ports and ICE)
