# Staging single-host stack (infra/staging/docker-compose.yml). Copy to `.env`:
#   cp infra/staging/.env.example infra/staging/.env
#
# **`DOMAIN_NAME`** can be written with `./scripts/set-domain-env.sh staging.example.com` (writes/updates `.env`).
# DNS A/AAAA records for **`DOMAIN_NAME`** must point at this VM before `./scripts/tls-bootstrap.sh` (HTTP-01).
#
DOMAIN_NAME=staging.example.com
CERTBOT_EMAIL=you@example.com
# CERTBOT_USE_STAGING=1

# --- Shared with infra/dev semantics (Compose substitution) ---
# RABBITMQ_USER=messaging
# RABBITMQ_PASS=messaging
# JWT_SECRET=staging-change-me

# --- MongoDB (mongo-init creates app user on first empty mongo-data volume) ---
# Dedicated user + password — **`infra/staging/mongo-init/010-create-messaging-app-user.js`** + messaging-service **`MONGODB_URI`**. All three are required (no Compose defaults).
MONGODB_DB_NAME=messaging
MESSAGING_DB_USER=messaging_app
MESSAGING_DB_PASSWORD=

# Messaging-service URLs through nginx (**`tls-bootstrap.sh`**):
# PUBLIC_APP_BASE_URL=https://staging.example.com

# Public S3 + MinIO (**`infra/staging/nginx/snippets/minio-s3-location.conf`**) **`S3_PUBLIC_BASE_URL`** default **`https://${DOMAIN_NAME}`**.
# **`VITE_S3_PUBLIC_BASE_URL`** (web-client build) should match origin — no `:9000` when nginx proxies **`/messaging-media/`**.
# # S3_PUBLIC_BASE_URL=https://cdn.example.com

