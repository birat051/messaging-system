    "@types/node": "^25.5.0",
    "@types/pino-http": "^5.8.4",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
