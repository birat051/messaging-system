    "mongodb": "^7.1.1",
    "multer": "^2.1.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "redis": "^5.11.0",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
