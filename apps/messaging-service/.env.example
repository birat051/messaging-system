# =============================================================================
# messaging-service — process env (Zod: `src/config/env.ts` → `loadEnv()`)
# =============================================================================
# Copy to `.env` in this directory for local `npm run dev`, or set in Docker /
# the host. Do not commit real secrets. Defaults shown in comments — omit a line
# to use the code default. Behavior and algorithms: `docs/PROJECT_PLAN.md`.
# =============================================================================

# --- Core --------------------------------------------------------------------
# NODE_ENV=development
# PORT=3000
# LOG_LEVEL=info

# LOG_LEVEL: fatal | error | warn | info | debug | trace | silent
# (defaults: info in production, else debug)

# --- Observability (Prometheus) ------------------------------------------------
# Exposes GET /metrics for scraping. Restrict by firewall; do not leave public.
# ENABLE_PROMETHEUS_METRICS=false

# --- Data plane --------------------------------------------------------------
# MONGODB_URI=mongodb://127.0.0.1:27017/messaging
# MONGODB_DB_NAME=messaging
# MONGODB_MAX_POOL_SIZE=10
# RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672
# MESSAGING_INSTANCE_ID=hostname-or-pod-name
# MESSAGING_REALTIME_DELIVERY_LOGS=false

# MESSAGING_REALTIME_DELIVERY_LOGS: when true, structured logs for each
# message:new / receipt emit from RabbitMQ → Socket.IO (see rabbitmq.ts).

# --- Redis (presence, rate limits, runtime config — not Socket.IO rooms) -------
# REDIS_URL=redis://127.0.0.1:6379
# LAST_SEEN_TTL_SECONDS=604800

# --- HTTP CORS (Express REST + swagger + `/metrics`) -------------------------
# Allowed browser origins (`Access-Control-Allow-Origin`). Default * — comma-separate multiple.
# REST_CORS_ALLOWED_ORIGINS=

# --- Socket.IO ---------------------------------------------------------------
# SOCKET_IO_CORS_ORIGIN=
# SOCKET_IO_REDIS_ADAPTER=false
# Discouraged — prefer in-memory rooms + RabbitMQ (PROJECT_PLAN.md §3.2.2).

# --- OpenAPI / Swagger -------------------------------------------------------
# OPENAPI_SPEC_PATH=
# Absolute path to openapi.yaml when not using default repo layout (e.g. Docker).

# --- S3-compatible object storage (MinIO, AWS S3, Cloudflare R2) ------------
# When S3_BUCKET is set, media upload + presign paths are enabled.
# S3_BUCKET=
# CLOUDFLARE_R2_ACCOUNT_ID=
# 32-char hex; when S3_ENDPOINT unset, default is https://<id>.r2.cloudflarestorage.com
# S3_REGION=us-east-1
# S3_ENDPOINT=
# S3_FORCE_PATH_STYLE=false
# S3_KEY_PREFIX=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# Required when S3_ENDPOINT is set (MinIO / S3 / R2 API token).
# S3_PUBLIC_BASE_URL=
# No trailing slash — browser-visible object URLs; MediaUploadResponse.url
# S3_PRESIGN_ENDPOINT=
# Override API origin for presign PUT only (e.g. internal minio:9000 vs public host)
# S3_ANONYMOUS_GET_OBJECT=false
# true: apply anonymous GetObject on MinIO for <img src>; false on AWS private buckets
# MEDIA_MAX_BYTES=104857600
# MEDIA_PRESIGN_TTL_SECONDS=300

# --- Auth (JWT) --------------------------------------------------------------
# JWT_SECRET=
# Required for auth routes and media when Bearer auth is used. HS256.

# EMAIL_VERIFICATION_REQUIRED=false
# EMAIL_VERIFICATION_TOKEN_TTL_HOURS=48
# ACCESS_TOKEN_TTL_SECONDS=86400
# REFRESH_TOKEN_TTL_SECONDS=604800
# GUEST_ACCESS_TOKEN_TTL_SECONDS=1800
# GUEST_REFRESH_TOKEN_TTL_SECONDS=1800
# GUEST_DATA_TTL_ENABLED=true
# GUEST_DATA_MONGODB_TTL_SECONDS=86400
# GUEST_SESSIONS_ENABLED=true
# GUEST_AUTH_RATE_LIMIT_WINDOW_SEC=3600
# GUEST_AUTH_RATE_LIMIT_MAX_PER_IP=20
# GUEST_AUTH_RATE_LIMIT_MAX_PER_FINGERPRINT=10
# GUEST_MESSAGE_SEND_RATE_LIMIT_MAX_PER_USER=30
# PASSWORD_RESET_TOKEN_TTL_HOURS=1
# PASSWORD_RESET_WEB_PATH=/reset-password
# FORGOT_PASSWORD_RATE_LIMIT_WINDOW_SEC=3600
# FORGOT_PASSWORD_RATE_LIMIT_MAX=5
# REGISTER_RATE_LIMIT_WINDOW_SEC=3600
# REGISTER_RATE_LIMIT_MAX=5
# RESEND_RATE_LIMIT_WINDOW_SEC=3600
# RESEND_RATE_LIMIT_MAX=3
# VERIFY_EMAIL_RATE_LIMIT_WINDOW_SEC=3600
# VERIFY_EMAIL_RATE_LIMIT_MAX=30

# --- SendGrid (when EMAIL_VERIFICATION_REQUIRED) -----------------------------
# SENDGRID_API_KEY=
# EMAIL_FROM=
# PUBLIC_APP_BASE_URL=
# EMAIL_VERIFICATION_WEB_PATH=/verify-email

# --- User search (`GET /v1/users/search`) -----------------------------------
# USER_SEARCH_RATE_LIMIT_WINDOW_SEC=60
# USER_SEARCH_RATE_LIMIT_MAX=60
# GUEST_USER_SEARCH_RATE_LIMIT_WINDOW_SEC=60
# GUEST_USER_SEARCH_RATE_LIMIT_MAX=30
# USER_SEARCH_MIN_QUERY_LENGTH=3
# USER_SEARCH_MAX_CANDIDATE_SCAN=200

# --- E2EE / devices ----------------------------------------------------------
# PUBLIC_KEY_FETCH_REQUIRE_DIRECT_THREAD=false
# PUBLIC_KEY_UPDATE_RATE_LIMIT_WINDOW_SEC=3600
# PUBLIC_KEY_UPDATE_RATE_LIMIT_MAX=30
# PUBLIC_KEY_JSON_BODY_MAX_BYTES=8192
# DEVICE_SYNC_RATE_LIMIT_WINDOW_SEC=3600
# DEVICE_SYNC_RATE_LIMIT_MAX=120
# Legacy: DEVICE_SYNC_BATCH_RATE_LIMIT_WINDOW_SEC, DEVICE_SYNC_BATCH_RATE_LIMIT_MAX
# DEVICE_SYNC_BATCH_JSON_BODY_MAX_BYTES=524288
# DEVICE_SYNC_NOTIFY_RATE_LIMIT_WINDOW_SEC=3600
# DEVICE_SYNC_NOTIFY_RATE_LIMIT_MAX=60

# --- Messaging / receipts / WebRTC (rate limits, Redis) ----------------------
# MESSAGE_SEND_RATE_LIMIT_WINDOW_SEC=60
# MESSAGE_SEND_RATE_LIMIT_MAX_PER_USER=120
# MESSAGE_SEND_RATE_LIMIT_MAX_PER_IP=360
# MESSAGE_SEND_RATE_LIMIT_MAX_PER_SOCKET=120
# MESSAGE_RECEIPT_RATE_LIMIT_WINDOW_SEC=60
# MESSAGE_RECEIPT_RATE_LIMIT_MAX_PER_USER=600
# MESSAGE_RECEIPT_RATE_LIMIT_MAX_PER_IP=2000
# MESSAGE_RECEIPT_RATE_LIMIT_MAX_PER_SOCKET=600
# WEBRTC_SIGNAL_RATE_LIMIT_WINDOW_SEC=60
# WEBRTC_SIGNAL_RATE_LIMIT_MAX_PER_USER=2000
# WEBRTC_SIGNAL_RATE_LIMIT_MAX_PER_IP=6000
# WEBRTC_SIGNAL_RATE_LIMIT_MAX_PER_SOCKET=2000

# --- Global REST (per IP; stacks with route-specific limits) -----------------
# GLOBAL_RATE_LIMIT_WINDOW_SEC=60
# GLOBAL_RATE_LIMIT_MAX=500

# =============================================================================
# Notes
# =============================================================================
# • Reverse proxy: `X-Forwarded-For` for getClientIp — `infra/dev/nginx/nginx.conf`
# • Runtime overrides: MongoDB `system_config` (email verification, guest, TTL)
# • Email verification matrix: `docs/openapi/openapi.yaml` (EMAIL_VERIFICATION_*)
# • Guest product rules: PROJECT_PLAN.md (Security — guest sessions), OpenAPI
# • Global vs per-route: both apply (separate Redis keys)
