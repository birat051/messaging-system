# Loaded for `vite build`. Override in `.env.production.local` (gitignored) if needed.
# Deployed SPA: https://ekko.biratbhattacharjee.com — nginx proxies `/v1` + `/socket.io` to messaging-service.
VITE_API_BASE_URL=/v1

# Path-style public reads — **`https://${origin}`** + **`/messaging-media/…`** from nginx proxy to MinIO
# (**`infra/staging/nginx/snippets/minio-s3-location.conf`**). Must match **`S3_PUBLIC_BASE_URL`** (**`https://${DOMAIN_NAME}`**) on messaging-service — no `:9000` on browser.
VITE_S3_PUBLIC_BASE_URL=https://ekko.biratbhattacharjee.com
VITE_S3_BUCKET=messaging-media
